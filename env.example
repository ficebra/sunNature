# Copier ce fichier en .env et remplir les valeurs

# Base de données PostgreSQL
# Sur Railway : copiez la DATABASE_URL depuis votre tableau de bord Railway
DATABASE_URL=postgresql://user:password@host:5432/jusnat_db

# Clé secrète JWT (changez cette valeur par une chaîne aléatoire longue)
JWT_SECRET=changez_cette_cle_par_une_valeur_aleatoire_longue_et_securisee

# Port du serveur (Railway le définit automatiquement)
PORT=3000

# Environnement
NODE_ENV=production
